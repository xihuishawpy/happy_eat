{
  "name": "happy-eat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server/index.js",
    "dev:worker": "npm run build && wrangler dev",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "d1:migrate": "wrangler d1 migrations apply happy-eat --remote",
    "d1:migrate:local": "wrangler d1 migrations apply happy-eat --local",
    "d1:export": "node scripts/export-sqlite-for-d1.mjs",
    "preview": "NODE_ENV=production node server/index.js",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "express": "^5.2.1",
    "lucide-react": "^1.23.0",
    "vite": "^8.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "playwright": "^1.57.0",
    "wrangler": "^4.110.0"
  }
}
